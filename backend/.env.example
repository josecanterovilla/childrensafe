# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ─── Base de datos (PostgreSQL) ─────────────────────────────
# Proyecto Supabase de ChildrenSafe (ref: hpyvgpxuctscsuoppgys, región us-east-1).
# La contraseña de la base se obtiene/resetea en el panel de Supabase:
#   Project Settings → Database → Connection string  (o "Reset database password")
#
# Conexión DIRECTA (recomendada para dev y migraciones):
#   postgresql://postgres:[PASSWORD]@db.hpyvgpxuctscsuoppgys.supabase.co:5432/postgres
#
# Conexión por POOLER (recomendada para producción/serverless):
#   postgresql://postgres.hpyvgpxuctscsuoppgys:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.hpyvgpxuctscsuoppgys.supabase.co:5432/postgres"

# ─── JWT ────────────────────────────────────────────────────
# Genera secretos fuertes:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=CHANGE_ME_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret
JWT_ACCESS_TTL=900          # 15 minutos (segundos)
JWT_REFRESH_TTL=2592000     # 30 días (segundos)

# ─── Emparejamiento ─────────────────────────────────────────
PAIRING_CODE_TTL=900        # 15 minutos (segundos)
PAIRING_MAX_ATTEMPTS=5      # intentos de canje antes de bloquear

# ─── Retención de datos ─────────────────────────────────────
LOCATION_RETENTION_HOURS=72 # purga automática de ubicaciones

# ─── Entrar con Google ──────────────────────────────────────
# Web OAuth Client ID de Google Cloud Console (audiencia del ID token).
# Es el MISMO valor que se usa como serverClientId en la app Flutter.
GOOGLE_CLIENT_ID=

# ─── Correo (Resend) ────────────────────────────────────────
# API key de https://resend.com (Dashboard → API Keys). Si se deja vacía, los códigos
# de confirmación/recuperación se registran en los logs (modo desarrollo, sin envío real).
RESEND_API_KEY=
# Remitente. Sin un dominio verificado en Resend, usa el de pruebas y solo podrás enviar
# a la dirección de tu propia cuenta Resend:
MAIL_FROM=ChildrenSafe <onboarding@resend.dev>

# ─── Notificaciones push (rellenar en Fase 1/2) ─────────────
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=
